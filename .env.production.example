# =============================================================================
# Macau POS — Production Environment Variables
# Copy to .env.production and fill in real values
# =============================================================================

# Database
DB_USER=pos_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=macau_pos

# App
AUTH_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
PLATFORM_DOMAIN=hkretailai.com

# SSL (for initial cert provisioning)
CERTBOT_EMAIL=admin@hkretailai.com

# ECS connection
ECS_HOST=YOUR_ECS_IP
ECS_USER=root

# Barcode lookup — GS1 China (ANCC / gds.org.cn)
GDS_REFRESH_TOKEN=

# Barcode lookup — GS1 Japan (Rakuten Ichiba + Yahoo Shopping JP fallback)
# Free developer registration:
#   https://webservice.rakuten.co.jp/  → RAKUTEN_APP_ID + RAKUTEN_ACCESS_KEY
#   https://e.developer.yahoo.co.jp/   → YAHOO_JP_APP_ID
# Rakuten requires BOTH applicationId (UUID) and accessKey (pk_...) and
# enforces an IP allowlist — register the production ECS IP in the dashboard.
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
YAHOO_JP_APP_ID=

# Intellipay (simpaylicity) payment gateway
# INTELLIPAY_KMS_KEY: 32-byte master key (hex) used to AES-256-GCM encrypt
#   tenant RSA private keys at rest. Generate once: `openssl rand -hex 32`.
#   NEVER change this after rows exist — existing ciphertexts become
#   unrecoverable. Treat as top-tier secret.
# INTELLIPAY_OUTBOUND_PUBLIC_KEY: Intellipay's RSA public key (PEM) used to
#   verify inbound webhook signatures. Supplied by Intellipay.
# INTELLIPAY_BASE_URL: API base, e.g. https://event.intellipay.io
INTELLIPAY_KMS_KEY=
INTELLIPAY_OUTBOUND_PUBLIC_KEY=
INTELLIPAY_BASE_URL=
