# =============================================================================
# Macau POS — Production Environment Variables
# Copy to .env.production and fill in real values
# =============================================================================

# Database
DB_USER=pos_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=macau_pos

# App
AUTH_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
PLATFORM_DOMAIN=hkretailai.com

# SSL (for initial cert provisioning)
CERTBOT_EMAIL=admin@hkretailai.com

# ECS connection
ECS_HOST=YOUR_ECS_IP
ECS_USER=root
