# =============================================================================
# Macau POS — Production Environment Variables
# Copy to .env.production and fill in real values
# =============================================================================

# Database
DB_USER=pos_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=macau_pos

# App
AUTH_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
PLATFORM_DOMAIN=hkretailai.com

# SSL (for initial cert provisioning)
CERTBOT_EMAIL=admin@hkretailai.com

# ECS connection
ECS_HOST=YOUR_ECS_IP
ECS_USER=root

# Barcode lookup — GS1 China (ANCC / gds.org.cn)
GDS_REFRESH_TOKEN=

# Barcode lookup — GS1 Japan (Rakuten Ichiba + Yahoo Shopping JP fallback)
# Free developer registration:
#   https://webservice.rakuten.co.jp/  → RAKUTEN_APP_ID
#   https://e.developer.yahoo.co.jp/   → YAHOO_JP_APP_ID
RAKUTEN_APP_ID=
YAHOO_JP_APP_ID=
