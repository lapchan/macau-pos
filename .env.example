# Application Configuration
# Copy this to .env and fill in values

NODE_ENV=development
PORT=3000

# Database (Docker default)
DATABASE_URL=postgresql://pos_dev:pos_dev_123@localhost:5433/macau_pos_dev

# Auth
AUTH_SECRET=

# Barcode lookup — GS1 Japan (Rakuten Ichiba + Yahoo Shopping JP fallback)
# Free developer registration:
#   https://webservice.rakuten.co.jp/  → RAKUTEN_APP_ID + RAKUTEN_ACCESS_KEY
#   https://e.developer.yahoo.co.jp/   → YAHOO_JP_APP_ID
# Rakuten now requires BOTH an applicationId (UUID) and accessKey (pk_...)
# and enforces an IP allowlist configured in the Rakuten app dashboard.
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
YAHOO_JP_APP_ID=

# Intellipay (simpaylicity) payment gateway
# INTELLIPAY_KMS_KEY: 32-byte master key (hex) for AES-256-GCM encryption of
#   tenant RSA private keys at rest. Generate: `openssl rand -hex 32`
# INTELLIPAY_OUTBOUND_PUBLIC_KEY: Intellipay's RSA public key (PEM) used to
#   verify inbound webhook signatures. Supplied by Intellipay.
# INTELLIPAY_BASE_URL: API base, e.g. https://event.intellipay.io
INTELLIPAY_KMS_KEY=
INTELLIPAY_OUTBOUND_PUBLIC_KEY=
INTELLIPAY_BASE_URL=

# Add more as needed during planning
